    screenGui.Name = "OrbGUI"
    screenGui.Parent = player.PlayerGui

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 260, 0, 140)
    frame.Position = UDim2.new(0, 10, 0, 10)
    frame.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
    frame.BackgroundTransparency = 0.2
    frame.BorderSizePixel = 2
    frame.BorderColor3 = Color3.fromRGB(0, 200, 255)
    frame.Parent = screenGui

    -- Заголовок (для перетаскивания)
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(0, 210, 0, 30)
    title.Position = UDim2.new(0.5, -105, 0, 5)
    title.BackgroundTransparency = 0.5
    title.BackgroundColor3 = Color3.fromRGB(0, 100, 150)
    title.Text = "SWILL Orb Collector"
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.TextScaled = true
    title.Font = Enum.Font.GothamBold
    title.Parent = frame

    -- Кнопка закрытия
    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 25, 0, 25)
    closeBtn.Position = UDim2.new(1, -30, 0, 5)
    closeBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    closeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    closeBtn.Text = "✕"
    closeBtn.TextScaled = true
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.Parent = frame
    closeBtn.MouseButton1Click:Connect(function()
        screenGui.Enabled = false
    end)

    -- Счётчик
    local scoreLabel = Instance.new("TextLabel")
    scoreLabel.Name = "ScoreLabel"
    scoreLabel.Size = UDim2.new(0, 210, 0, 25)
    scoreLabel.Position = UDim2.new(0.5, -105, 0, 40)
    scoreLabel.BackgroundTransparency = 1
    scoreLabel.Text = "Собрано: 0"
    scoreLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    scoreLabel.TextScaled = true
    scoreLabel.Font = Enum.Font.Gotham
    scoreLabel.Parent = frame

    -- Статус
    local statusLabel = Instance.new("TextLabel")
    statusLabel.Name = "StatusLabel"
    statusLabel.Size = UDim2.new(0, 210, 0, 20)
    statusLabel.Position = UDim2.new(0.5, -105, 0, 65)
    statusLabel.BackgroundTransparency = 1
    statusLabel.Text = "Статус: ВЫКЛ"
    statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    statusLabel.TextScaled = true
    statusLabel.Font = Enum.Font.Gotham
    statusLabel.Parent = frame

    -- Кнопка вкл/выкл
    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Name = "ToggleButton"
    toggleBtn.Size = UDim2.new(0, 180, 0, 35)
    toggleBtn.Position = UDim2.new(0.5, -90, 0, 90)
    toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 80)
    toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    toggleBtn.TextScaled = true
    toggleBtn.Font = Enum.Font.GothamBold
    toggleBtn.Text = "ВКЛЮЧИТЬ"
    toggleBtn.Parent = frame

    -- ------------------------------------------------------------
    -- ПЕРЕТАСКИВАНИЕ МЕНЮ
    -- ------------------------------------------------------------
    local dragging = false
    local dragStartMousePos = nil
    local dragStartFramePos = nil

    title.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStartMousePos = input.Position
            dragStartFramePos = frame.Position
        end
    end)

    title.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStartMousePos
            frame.Position = UDim2.new(
                dragStartFramePos.X.Scale,
                dragStartFramePos.X.Offset + delta.X,
                dragStartFramePos.Y.Scale,
                dragStartFramePos.Y.Offset + delta.Y
            )
        end
    end)

    return toggleBtn, statusLabel, scoreLabel
end

-- Инициализация
local toggleButton, statusLabel, scoreLabel = createGUI()
toggleButton.MouseButton1Click:Connect(function()
    autoCollect = not autoCollect
    if autoCollect then
        toggleButton.Text = "ВЫКЛЮЧИТЬ"
        toggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        statusLabel.Text = "Статус: ВКЛ"
        startAutoCollect()
    else
        toggleButton.Text = "ВКЛЮЧИТЬ"
        toggleButton.BackgroundColor3 = Color3.fromRGB(0, 200, 80)
        statusLabel.Text = "Статус: ВЫКЛ"
        stopAutoCollect()
    end
end)

updateScoreGUI()
print("[SWILL] Исправленный сборщик орбов готов. Нажми ВКЛЮЧИТЬ.")

-- Смена персонажа
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    if autoCollect then
        stopAutoCollect()
        startAutoCollect()
    end
end)

-- Завершение
game:BindToClose(function()
    stopAutoCollect()
end)
