local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()

-- НАСТРОЙКИ (подбери под себя)
local CONFIG = {
    MoveSpeed = 55,                     -- скорость ховерборда
    OrbNames = {"Orb", "OrbPart", "Collectible"}, -- имена орбов
    GroundOffset = 2.5,                 -- высота над полом
    MaxHeightDifference = 15,           -- разрешённый перепад высот
    ArriveDistance = 4,                 -- дистанция для сбора
    SearchCooldown = 0.1,               -- пауза между поисками, если орбов нет
}

-- Состояние
local autoCollect = false
local score = 0
local currentTarget = nil
local moveLoop = nil
local searchTimer = 0

-- Поиск всех орбов (по имени)
local function findAllOrbs()
    local orbs = {}
    for _, name in ipairs(CONFIG.OrbNames) do
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and obj.Name == name and obj.Parent ~= character then
                table.insert(orbs, obj)
            end
        end
    end
    return orbs
end

-- Поиск ближайшего подходящего орба (с учётом высоты)
local function findNearestOrb()
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local charPos = hrp.Position
    local bestDist = math.huge
    local bestOrb = nil

    local allOrbs = findAllOrbs()
    for _, orb in ipairs(allOrbs) do
        if orb and orb.Parent then
            local dist = (orb.Position - charPos).Magnitude
            local heightDiff = orb.Position.Y - charPos.Y
            if heightDiff < CONFIG.MaxHeightDifference and heightDiff > -5 then
                if dist < bestDist then
                    bestDist = dist
                    bestOrb = orb
                end
            end
        end
    end
    return bestOrb
end

-- Определение высоты земли (Raycast)
local function getGroundY(position)
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {character}
    local origin = position + Vector3.new(0, 10, 0)
    local result = workspace:Raycast(origin, Vector3.new(0, -100, 0), raycastParams)
    if result then
        return result.Position.Y
    else
        return position.Y - 5
    end
end

-- Получить целевую позицию для орба (на земле)
local function getTargetPosition(orb)
    if not orb then return nil end
    local groundY = getGroundY(orb.Position)
    local targetY = math.max(groundY + CONFIG.GroundOffset, orb.Position.Y - 2) -- страховка
    return Vector3.new(orb.Position.X, targetY, orb.Position.Z)
end

-- Обновить GUI счётчика
local function updateScoreGUI()
    local gui = player.PlayerGui:FindFirstChild("OrbGUI")
    if gui then
        local label = gui:FindFirstChild("ScoreLabel")
        if label then label.Text = "Собрано: " .. tostring(score) end
    end
end

-- Остановка движения
local function stopMoving()
    if moveLoop then
        moveLoop:Disconnect()
        moveLoop = nil
    end
    currentTarget = nil
    local humanoid = character:FindFirstChild("Humanoid")
    if humanoid then humanoid.AutoRotate = true end
end

-- ЗАПУСК БЕСКОНЕЧНОГО СБОРА (исправленная логика)
local function startAutoCollect()
    if moveLoop then return end
    local humanoid = character:FindFirstChild("Humanoid")
    if humanoid then humanoid.AutoRotate = false end

    moveLoop = RunService.Heartbeat:Connect(function(deltaTime)
        if not autoCollect then return end

        -- Проверка персонажа
        if not character or not character.Parent then
            character = player.CharacterAdded:Wait()
            return
        end
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        -- Если нет цели или цель уничтожена – ищем новую
        if not currentTarget or not currentTarget.Parent then
            currentTarget = findNearestOrb()
            if not currentTarget then
                -- Если орбов нет, ждём немного, чтобы не грузить процессор
                task.wait(CONFIG.SearchCooldown)
                return
            end
            -- Цель найдена – продолжаем
        end

        -- Теперь у нас есть текущая цель
        local targetPos = getTargetPosition(currentTarget)
        if not targetPos then
            currentTarget = nil
            return
        end

        local currentPos = hrp.Position
        local direction = (targetPos - currentPos)
        local distance = direction.Magnitude

        -- Если достигли орба – собираем
        if distance < CONFIG.ArriveDistance then
            if currentTarget and currentTarget.Parent then
                currentTarget:Destroy()
            end
            score = score + 1
            updateScoreGUI()
            currentTarget = nil   -- сброс для поиска нового на следующем тике
            return
        end

        -- Движение с фиксированной скоростью (ховерборд)
        local step = direction.Unit * CONFIG.MoveSpeed * deltaTime
        if step.Magnitude >= distance then
            hrp.CFrame = CFrame.new(targetPos)
        else
            hrp.CFrame = hrp.CFrame + step
        end
    end)
end

-- Остановка всего
local function stopAutoCollect()
    autoCollect = false
    stopMoving()
end

-- СОЗДАНИЕ GUI С ПЕРЕТАСКИВАНИЕМ
